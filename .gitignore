## Ignore Visual Studio temporary files, build results, and
## files generated by common Visual Studio add-ons.
##
## Based on GitHub's VisualStudio.gitignore:
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.env

# Visual Studio workspace/cache
.vs/
ipch/
*.VC.db
*.VC.VC.opendb
*.opendb
*.opensdf
*.sdf
*.ncb

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
[Rr]elWithDebInfo/
[Mm]inSizeRel/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[Aa][Rr][Mm]64[Ee][Cc]/
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/
bld/
build/
out/

# C++ platform build directories commonly generated beside .sln/.vcxproj files
x64/
x86/

# Files built by Visual Studio / MSVC
*_i.c
*_p.c
*_h.h
*.aps
*.cachefile
*.idb
*.iobj
*.ipdb
*.ilk
*.lastbuildstate
*.log
*.obj
*.pch
*.pdb
*.pgc
*.pgd
*.res
*.rsp
!Directory.Build.rsp
*.sbr
*.tlog
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj

# Local test and benchmark output
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
BenchmarkDotNet.Artifacts/

# Coverage/profiling output
*.coverage
*.coveragexml
*.psess
*.vsp
*.vspx
*.sap

# NuGet/package restore output
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# ReSharper / Rider / other IDE caches
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
.idea/

# VS Code workspace files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/

# Local history
**/.localhistory/
.vshistory/

# OS/editor noise
*.swp
*~
~$*
Thumbs.db
Desktop.ini
